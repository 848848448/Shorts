<!DOCTYPE html>
<html lang="yi" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Empire Shorts</title>
    <link rel="stylesheet" href="style.css">
    
    <script src="https://www.gstatic.com/firebasejs/8.10.0/firebase-app.js"></script>
    <script src="https://www.gstatic.com/firebasejs/8.10.0/firebase-database.js"></script>
    <script src="https://www.gstatic.com/firebasejs/8.10.0/firebase-storage.js"></script>
</head>
<body>
    <header class="header">
        <div id="top-sym" class="logo-circle">💎</div>
        <div class="logo-text">Shorts Hub</div>
    </header>

    <div id="home-view" class="view-active">
        <div class="stories-bar">
            <div class="story-btn" onclick="showReels()">🎬</div>
            <div class="story-btn" onclick="showSection('music')">🎵</div>
            <div class="story-btn" onclick="showSection('pics')">🖼️</div>
            <div class="story-btn" onclick="showSection('text')">✍️</div>
        </div>
        
        <div class="grid-layout">
            <button class="nav-card" onclick="showReels()"><i>🎬</i><span>ווידעאס</span></button>
            <button class="nav-card" onclick="showSection('music')"><i>🎵</i><span>מוזיק</span></button>
            <button class="nav-card" onclick="showSection('pics')"><i>🖼️</i><span>בילדער</span></button>
            <button class="nav-card" onclick="showSection('text')"><i>✍️</i><span>טעקסט</span></button>
        </div>
    </div>

    <div id="reels-overlay" class="reels-layer">
        <div class="close-x" onclick="closeReels()">✕</div>
        <div id="reels-container"></div>
    </div>

    <nav class="bottom-nav">
        <div onclick="location.reload()">🏠</div>
        <div onclick="showReels()">🎬</div>
        <div class="upload-plus" onclick="document.getElementById('file-input').click()">⊕</div>
        <div onclick="showSection('text')">✍️</div>
        <div onclick="alert('Settings coming soon')">⚙️</div>
    </nav>

    <input type="file" id="file-input" style="display:none" onchange="startUpload(this)">
    <script src="script.js"></script>
</body>
              </html>
